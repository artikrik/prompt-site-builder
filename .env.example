# prompt-site-builder — Environment Variables
# Copy to .env and fill with real values before deployment.

# ── Database ─────────────────────────────────────
POSTGRES_DB=promptsite
POSTGRES_USER=promptsite
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────
REDIS_PORT=6379

# ── Auth ─────────────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── AI APIs ──────────────────────────────────────

# LLM Provider Selection
LLM_PROVIDER=openai
IMAGE_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google
GOOGLE_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com

# MiMo
MIMO_API_KEY=...
MIMO_BASE_URL=https://api.mimo.ai/v1
MIMO_MODEL=mimo-v2.5

# BFL (Flux image generation)
BFL_API_KEY=...

# Apify
APIFY_TOKEN=...

# ── Encryption ──────────────────────────────────────
# Encryption key for stored API keys (min 16 chars for AES-256)
ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# ── Ports ────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ── Enrichment APIs ──────────────────────────────
FACEBOOK_ACCESS_TOKEN=
GOOGLE_MAPS_API_KEY=
INSTAGRAM_ACCESS_TOKEN=
ENRICHMENT_AUTO_RUN=true
ENRICHMENT_DEFAULT_SOURCES=instagram,facebook,googleMaps

# ── Hugo / Publishing ────────────────────────────
HUGO_SITES_PATH=./client-sites
HUGO_BINARY_PATH=hugo
BASE_DOMAIN=sitenow.pp.ua
