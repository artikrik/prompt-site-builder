generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  GENERATING
  GENERATED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum VariantStatus {
  DRAFT
  GENERATING
  GENERATED
  PUBLISHED
}

enum JobType {
  SCRAPE_LEAD
  ENRICH_LEAD
  GENERATE_SITE
  PUBLISH_SITE
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum WidgetType {
  BOOKING
  PAYMENT
}

enum ImageAssetType {
  HERO
  LOGO
  THUMBNAIL
  GALLERY
}

enum UserRole {
  ADMIN
  OPERATOR
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  projects Project[]
}

model Lead {
  id           String     @id @default(uuid())
  businessName String
  slug         String     @unique
  phone        String?
  email        String?
  address      String?
  city         String?
  category     String?
  description  String?
  website      String?
  socialUrl    String?
  source       String
  status       LeadStatus @default(NEW)
  tags         String[]
  scrapedData  Json       @default("{}")

  // Payment & Booking
  easyweekEnabled   Boolean  @default(false)
  easyweekApiKey    String?
  wayforpayEnabled  Boolean  @default(false)
  wayforpayMerchant String?
  wayforpaySecret   String?
  monobankEnabled   Boolean  @default(false)
  monobankApiKey    String?

  // Enrichment
  enrichmentData    Json       @default("{}")
  enrichedAt        DateTime?
  enrichmentSources String[]   @default([])

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  projects Project[]
}

model SiteVariant {
  id           String        @id @default(uuid())
  projectId    String
  variantName  String
  status       VariantStatus @default(DRAFT)
  hugoConfig   Json          @default("{}")
  content      Json          @default("{}")
  modelUsed    String?
  imageModel   String?
  themeName    String?
  previewUrl   String?
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  project      Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
	  activeForProject   Project?      @relation("ActiveVariant")
  assets       SiteAsset[]
  jobs         GenerationJob[]

  @@index([projectId])
}

model Project {
  id           String        @id @default(uuid())
  leadId       String
  slug         String        @unique
  status       ProjectStatus @default(DRAFT)
  hugoConfig   Json          @default("{}")
  generatedAt  DateTime?
  publishedAt  DateTime?
  publishedUrl String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  lead         Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  userId       String?
  jobs         GenerationJob[]
  assets       SiteAsset[]
  widgets         ClientWidget[]

  activeVariantId String? @unique
  activeVariant   SiteVariant? @relation("ActiveVariant", fields: [activeVariantId], references: [id])
  variants        SiteVariant[]
}

model GenerationJob {
  id          String    @id @default(uuid())
  projectId   String
  type        JobType
  status      JobStatus @default(PENDING)
  result      Json?
  error       String?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  variantId   String?
  variant     SiteVariant? @relation(fields: [variantId], references: [id])
}

model SiteAsset {
  id        String         @id @default(uuid())
  projectId String
  filePath  String
  assetType ImageAssetType
  sourceUrl String?
  createdAt DateTime       @default(now())

  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  variantId String?
  variant   SiteVariant? @relation(fields: [variantId], references: [id])
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model ClientWidget {
  id        String     @id @default(uuid())
  projectId String
  type      WidgetType
  config    Json       @default("{}")
  enabled   Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
