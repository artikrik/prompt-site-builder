{
  # Global options
  admin off
  on_demand_tls {
    ask http://backend:3000/health
  }
  log {
    output stdout
    format json
  }
}

# Dashboard + API (same domain to avoid DNS subdomain requirement)
https://sitenow.pp.ua, https://www.sitenow.pp.ua {
  # API proxy — /api/* routes to backend (strip /api prefix)
  handle_path /api/* {
    reverse_proxy backend:3000

    header {
      X-Content-Type-Options nosniff
      X-Frame-Options DENY
      Referrer-Policy strict-origin-when-cross-origin
    }
  }

  # Everything else → frontend
  handle {
    reverse_proxy frontend:5173
  }

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

http://sitenow.pp.ua, http://www.sitenow.pp.ua {
  redir https://sitenow.pp.ua{uri}
}

# API
https://api.sitenow.pp.ua {
  reverse_proxy backend:3000

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
  }
}

http://api.sitenow.pp.ua {
  redir https://api.sitenow.pp.ua{uri}
}

# Client subdomains — HTTP (plain, no TLS)
# Proxied from Nginx on port 80, TLS terminated by Nginx or Caddy on-demand
http://*.sitenow.pp.ua {
  root * /var/www/client-sites/{labels.3}

  file_server {
    precompressed gzip br
  }

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
  }

  # SPA fallback for client sites
  try_files {path} {path}/ /index.html

  # Cache static assets
  @static {
    path /images/* /css/* /js/*
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
}

# On-Demand TLS for client subdomains
# Wildcard: *.sitenow.pp.ua
https://*.sitenow.pp.ua {
  tls {
    on_demand
  }

  root * /var/www/client-sites/{labels.3}

  file_server {
    precompressed gzip br
  }

  header {
    X-Content-Type-Options nosniff
    X-Frame-Options SAMEORIGIN
    Referrer-Policy strict-origin-when-cross-origin
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:"
  }

  # SPA fallback for client sites
  try_files {path} {path}/ /index.html

  # Cache static assets
  @static {
    path /images/* /css/* /js/*
  }
  header @static Cache-Control "public, max-age=31536000, immutable"
}
